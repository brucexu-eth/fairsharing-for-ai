# Deployer private key (no 0x prefix needed for some tools)
PRIVATE_KEY=

# Additional agent demo wallets (Sepolia/Base Sepolia only, never use real funds)
AGENT_1_PRIVATE_KEY=
AGENT_2_PRIVATE_KEY=
AGENT_3_PRIVATE_KEY=

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Block explorer API key (Basescan)
BASESCAN_API_KEY=

# ERC-8004 Registry address on Base (set for mainnet verification)
ERC8004_REGISTRY_ADDRESS=

# Deployed contract addresses (filled after deployment)
FACTORY_ADDRESS=
FS_PROJECT_ADDRESS=
REWARD_TOKEN_ADDRESS=

# AI agent demo (media-demo.ts)
# Get REWARD_TOKEN_ADDRESS: cast call $FS_PROJECT_ADDRESS "rewardToken()(address)" --rpc-url https://sepolia.base.org
ANTHROPIC_API_KEY=
# Optional: override model (default: claude-haiku-3-5, use claude-opus-4-6 for best quality)
ANTHROPIC_MODEL=claude-haiku-3-5
