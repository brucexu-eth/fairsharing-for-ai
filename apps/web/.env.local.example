# Required: deployed FSProjectFactory address
NEXT_PUBLIC_FACTORY_ADDRESS=

# Optional: pre-fill the demo page project address
NEXT_PUBLIC_DEMO_PROJECT_ADDRESS=

# Demo API route — override with Base Sepolia keys + RPC for testnet demo
# Defaults to hardhat local node (http://127.0.0.1:8545) with well-known test keys
DEMO_RPC_URL=http://127.0.0.1:8545
DEMO_OWNER_KEY=
DEMO_AGENT_1_KEY=
DEMO_AGENT_2_KEY=
DEMO_AGENT_3_KEY=
