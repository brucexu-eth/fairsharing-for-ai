{
  "name": "fairsharing-for-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "agent:submit": "node --loader ts-node/esm scripts/agent-runner.ts submit",
    "agent:vote": "node --loader ts-node/esm scripts/agent-runner.ts vote",
    "agent:round": "node --loader ts-node/esm scripts/agent-runner.ts round",
    "demo:media": "bun scripts/media-demo.ts",
    "demo:media:5": "bun scripts/media-demo.ts --rounds=5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "viem": "^2.13.5"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
